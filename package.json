{
    "name": "<My Game>",
    "version": "0.1.0",
    "private": true,
    "sideEffects": [
        "*.css"
    ],
    "homepage": "./",
    "dependencies": {
        "@tolokoban/react-state": "^0.7.3",
        "@tolokoban/tgd": "^2.0.95",
        "@tolokoban/type-guards": "^0.9.0",
        "build-react-routes": "^0.10.8",
        "json5": "^2.2.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "scripts": {
        "generate": "npm run routes",
        "routes": "build-react-routes ./src/app",
        "analyse": "webpack --profile --json > stats.json",
        "start": "rspack serve --mode=development",
        "build": "rspack --mode=production",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build",
        "format": "oxfmt",
        "lint": "oxlint",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "eslintConfig": {},
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@rspack/cli": "^1.6.6",
        "@rspack/core": "^1.6.6",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^13.0.1",
        "css-loader": "^6.11.0",
        "file-loader": "^6.2.0",
        "gh-pages": "^6.1.1",
        "highlight.js": "^11.11.1",
        "html-webpack-plugin": "^5.6.0",
        "jest": "^30.1.3",
        "markdown-to-jsx": "^9.7.6",
        "mini-css-extract-plugin": "^2.9.4",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "raw-loader": "^4.0.2",
        "rehype-highlight": "^7.0.2",
        "rehype-highlight-code-lines": "^1.2.0",
        "remark-emoji": "^5.0.2",
        "remark-gfm": "^4.0.1",
        "remark-images": "^4.1.0",
        "save-as": "^0.1.8",
        "style-loader": "^3.3.4",
        "ts-jest": "^29.4.2",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "url-loader": "^4.1.1",
        "webpack-dev-server": "^5.2.3",
        "webpack-shell-plugin-next": "^2.3.3",
        "workbox-webpack-plugin": "^7.3.0"
    }
}